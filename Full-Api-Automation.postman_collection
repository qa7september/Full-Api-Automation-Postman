									"    let parte1 = `usuário_${Math.random().toString(36).substring(2, 18)}`;\r",
									"    let parte2 = Math.random().toString(36).substring(2, 23);\r",
									"    let usernameFinal = `${parte1}_${parte2}`;\r",
									"\r",
									"    while (usernameFinal.length < 41) {\r",
									"        usernameFinal += Math.random().toString(36).charAt(2);\r",
									"    }\r",
									"\r",
									"    return usernameFinal.substring(0, 41);\r",
									"}\r",
